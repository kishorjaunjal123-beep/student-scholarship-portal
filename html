<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neuroscholar | AI Web Mentor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #050505;
            --text-color: #ffffff;
            --glass-bg: rgba(255, 255, 255, 0.05); /* Lighter for glass effect */
            --glass-border: rgba(255, 255, 255, 0.15); /* More visible border */
            --glass-blur: 20px; /* Increased blur */
            --accent-color: #ffffff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            /* Enhanced background gradients to make glass look better */
            background: 
                radial-gradient(circle at 10% 20%, #1a1a40 0%, transparent 40%),
                radial-gradient(circle at 80% 80%, #2a1010 0%, transparent 40%),
                radial-gradient(circle at 50% 50%, #111 0%, #050505 100%);
        }

        /* --- UTILITIES --- */
        .hidden { display: none !important; }

        /* --- TOP BAR --- */
        .top-bar {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px 60px;
            position: relative;
            z-index: 100;
        }

        .nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            padding: 12px 40px;
            border-radius: 100px;
            border: 1px solid var(--glass-border);
        }

        .nav-links a {
            color: var(--text-color);
            text-decoration: none;
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            opacity: 0.5;
            transition: 0.3s;
            cursor: pointer;
        }

        .nav-links a:hover { opacity: 1; }

        .top-login { position: absolute; right: 60px; }

        .login-link {
            color: var(--text-color);
            text-decoration: none;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            opacity: 0.6;
            transition: 0.3s;
            cursor: pointer;
        }

        .login-link:hover { opacity: 1; }

        /* --- HEADER --- */
        header {
            width: 100%;
            padding-top: 20px;
            text-align: center;
        }

        h1 {
            font-size: clamp(2.5rem, 8vw, 5.5rem);
            font-weight: 900;
            letter-spacing: 15px;
            text-transform: uppercase;
            margin-right: -15px;
            line-height: 1;
        }

        /* --- MAIN LANDING CONTENT --- */
        main {
            flex: 1;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 10%;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            padding: 40px;
            border-radius: 24px;
            width: 320px;
        }

        .middle-text {
            font-size: 13px;
            line-height: 1.8;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 300;
        }

        .left-mid { text-align: left; }
        .right-mid { text-align: right; }

        /* --- UPDATED: GLASSMORPHISM PAGE OVERLAY --- */
        .page-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Change from solid black to semi-transparent to allow background gradients to show */
            background: rgba(0, 0, 0, 0.4); 
            z-index: 200;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-y: auto;
            padding: 40px 0;
            /* Added slight blur to the background when forms are open */
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        /* --- UPDATED: GLASSMORPHISM FORM CONTAINER --- */
        .form-container {
            width: 100%;
            max-width: 700px;
            background: rgba(255, 255, 255, 0.03); 
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            /* Add highlight to top-left for 3D glass look */
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            border-left: 1px solid rgba(255, 255, 255, 0.2);
            padding: 50px;
            border-radius: 30px;
            margin: 20px;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.2);
        }

        .login-container { max-width: 420px; }

        /* --- ABOUT SECTION STYLES --- */
        .about-container {
            max-width: 900px;
            text-align: center;
        }

        .about-title {
            font-size: 32px;
            font-weight: 900;
            letter-spacing: 8px;
            text-transform: uppercase;
            margin-bottom: 30px;
        }

        .about-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .about-feature {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--glass-border);
            padding: 30px 20px;
            border-radius: 20px;
        }

        /* --- REGISTRATION/LOGIN FORM STYLES --- */
        .reg-title {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 5px;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 40px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .full-width { grid-column: span 2; }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .input-group label {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 2px;
            opacity: 0.6;
        }

        /* UPDATED: Glassy inputs */
        .input-group input, .input-group select {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 14px 15px;
            border-radius: 12px;
            color: white;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: 0.3s;
        }

        .input-group input:focus {
            border-color: rgba(255, 255, 255, 0.5);
            background: rgba(255, 255, 255, 0.1);
        }

        .submit-btn {
            width: 100%;
            padding: 15px;
            margin-top: 30px;
            background: white;
            color: black;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: 0.3s;
        }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255,255,255,0.2);
        }

        .back-btn {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: white;
            text-decoration: none;
            font-size: 10px;
            letter-spacing: 2px;
            opacity: 0.5;
            text-transform: uppercase;
        }

        .switch-auth {
            display: block;
            text-align: center;
            margin-top: 15px;
            color: white;
            font-size: 10px;
            text-decoration: none;
            opacity: 0.5;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- FOOTER --- */
        footer {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding: 40px 10% 60px 10%;
        }

        .footer-link {
            color: var(--text-color);
            text-decoration: none;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            transition: 0.3s;
            opacity: 0.6;
        }

        @media (max-width: 1000px) {
            h1 { letter-spacing: 8px; margin-right: -8px; }
            main { flex-direction: column; gap: 20px; }
            .glass-card { width: 90%; }
            .form-grid { grid-template-columns: 1fr; }
            .full-width { grid-column: span 1; }
            .about-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div id="landing-page" style="display: contents;">
        <div class="top-bar">
            <nav>
                <ul class="nav-links">
                    <li><a onclick="showAbout()">About</a></li>
                    <li><a href="#">Vision</a></li>
                    <li><a href="#">Schemes</a></li>
                </ul>
            </nav>
            <div class="top-login">
                <a class="login-link" onclick="showLogin()">Login</a>
            </div>
        </div>

        <header>
            <h1>NEUROSCHOLAR</h1>
        </header>

        <main>
            <div class="glass-card">
                <div class="middle-text left-mid">
                    Elevating education through<br>
                    intelligent automation.<br>
                    <b>Your AI Web Mentor.</b>
                </div>
            </div>
            <div class="glass-card">
                <div class="middle-text right-mid">
                    Centralizing every<br>
                    scholarship opportunity.<br>
                    <b>One site. No limits.</b>
                </div>
            </div>
        </main>

        <footer>
            <div class="footer-left">
                <a href="#" class="footer-link" onclick="showRegistration()">Registration</a>
            </div>
            <div class="footer-right">
                <a href="#" class="footer-link">Find Scholarship &rarr;</a>
            </div>
        </footer>
    </div>

    <!-- ABOUT PAGE -->
    <div id="about-page" class="page-overlay hidden">
        <div class="form-container about-container">
            <h2 class="about-title">About Neuroscholar</h2>
            <p class="about-description" style="font-size: 14px; line-height: 2; opacity: 0.8; margin-bottom: 40px;">
                Neuroscholar is a next-generation AI-driven platform designed to bridge the gap between ambitious students and life-changing financial opportunities.
            </p>
            <div class="about-grid">
                <div class="about-feature">
                    <h3>AI Mentorship</h3>
                    <p>Intelligent algorithms that guide you through the complex application process.</p>
                </div>
                <div class="about-feature">
                    <h3>Pan-India Access</h3>
                    <p>A centralized hub containing thousands of scholarships available within India.</p>
                </div>
                <div class="about-feature">
                    <h3>Smart Matching</h3>
                    <p>Precision matching based on your academic profile and unique background.</p>
                </div>
            </div>
            <a href="#" class="back-btn" onclick="showLanding()" style="margin-top: 50px; opacity: 1;">← Back to Home</a>
        </div>
    </div>

    <!-- LOGIN PAGE (Updated Glass Section) -->
    <div id="login-page" class="page-overlay hidden">
        <div class="form-container login-container">
            <h2 class="reg-title">Login</h2>
            <form onsubmit="handleAuth(event, 'Login')">
                <div class="input-group">
                    <label>Email Address</label>
                    <input type="email" placeholder="Enter your email" required>
                </div>
                <div class="input-group" style="margin-top: 20px;">
                    <label>Password</label>
                    <input type="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="submit-btn">Sign In</button>
                <a href="#" class="switch-auth" onclick="showRegistration()">Don't have an account? Register</a>
                <a href="#" class="back-btn" onclick="showLanding()">← Back to Home</a>
            </form>
        </div>
    </div>

    <!-- REGISTRATION PAGE (Updated Glass Section) -->
    <div id="registration-page" class="page-overlay hidden">
        <div class="form-container">
            <h2 class="reg-title">Register</h2>
            <form id="regForm" onsubmit="handleAuth(event, 'Registration')">
                <div class="form-grid">
                    <div class="input-group">
                        <label>First Name</label>
                        <input type="text" required>
                    </div>
                    <div class="input-group">
                        <label>Surname</label>
                        <input type="text" required>
                    </div>
                    <div class="input-group">
                        <label>Date of Birth</label>
                        <input type="date" required>
                    </div>
                    <div class="input-group">
                        <label>Gender</label>
                        <select required>
                            <option value="" disabled selected>Select</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="input-group full-width">
                        <label>Email</label>
                        <input type="email" required>
                    </div>
                    <div class="input-group">
                        <label>Phone Number</label>
                        <input type="tel" required>
                    </div>
                    <div class="input-group">
                        <label>City</label>
                        <input type="text" required>
                    </div>
                </div>
                <button type="submit" class="submit-btn">Create Account</button>
                <a href="#" class="back-btn" onclick="showLanding()">← Back to Home</a>
            </form>
        </div>
    </div>

    <script>
        const landingPage = document.getElementById('landing-page');
        const regPage = document.getElementById('registration-page');
        const loginPage = document.getElementById('login-page');
        const aboutPage = document.getElementById('about-page');

        function showLogin() {
            landingPage.classList.add('hidden');
            regPage.classList.add('hidden');
            aboutPage.classList.add('hidden');
            loginPage.classList.remove('hidden');
            document.body.style.overflow = 'auto';
        }

        function showRegistration() {
            landingPage.classList.add('hidden');
            loginPage.classList.add('hidden');
            aboutPage.classList.add('hidden');
            regPage.classList.remove('hidden');
            document.body.style.overflow = 'auto';
        }

        function showAbout() {
            landingPage.classList.add('hidden');
            loginPage.classList.add('hidden');
            regPage.classList.add('hidden');
            aboutPage.classList.remove('hidden');
            document.body.style.overflow = 'auto';
        }

        function showLanding() {
            landingPage.classList.remove('hidden');
            regPage.classList.add('hidden');
            loginPage.classList.add('hidden');
            aboutPage.classList.add('hidden');
            document.body.style.overflow = 'hidden';
        }

        function handleAuth(event, type) {
            event.preventDefault();
            alert(type + " Successful!");
            showLanding();
        }
    </script>

</body>
</html>
