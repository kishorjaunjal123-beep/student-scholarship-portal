<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neuroscholar | AI Web Mentor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #050505;
            --text-color: #ffffff;
            --dim-text: rgba(255, 255, 255, 0.5);
            --accent-color: #ffffff;
            --glass: rgba(255, 255, 255, 0.05);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            background: radial-gradient(circle at center, #111 0%, #050505 100%);
        }

        /* --- 1. TOP NAVIGATION (Restored) --- */
        nav {
            width: 100%;
            display: flex;
            justify-content: center;
            padding-top: 30px;
            z-index: 100;
        }

        .nav-links {
            display: flex;
            gap: 40px;
            list-style: none;
            background: var(--glass);
            backdrop-filter: blur(10px);
            padding: 12px 40px;
            border-radius: 50px;
            border: 1px solid var(--glass-border);
        }

        .nav-links a {
            color: var(--text-color);
            text-decoration: none;
            font-size: 11px;
            letter-spacing: 2px;
            text-transform: uppercase;
            opacity: 0.6;
            transition: 0.3s;
        }

        .nav-links a:hover {
            opacity: 1;
        }

        /* --- 2. HEADER (Title) --- */
        header {
            width: 100%;
            padding-top: 40px;
            text-align: center;
            z-index: 10;
        }

        h1 {
            font-size: clamp(2rem, 6vw, 4rem);
            font-weight: 700;
            letter-spacing: 18px;
            text-transform: uppercase;
        }

        /* --- 3. MAIN (Left & Right Center Text) --- */
        main {
            flex: 1;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 80px;
        }

        .middle-text {
            max-width: 250px;
            font-size: 14px;
            line-height: 1.6;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 300;
        }

        .left-mid { text-align: left; }
        .right-mid { text-align: right; }

        /* --- 4. FOOTER (Login/Reg & Find) --- */
        footer {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding: 40px 80px 60px 80px;
        }

        .footer-left {
            display: flex;
            gap: 30px;
        }

        .footer-right {
            text-align: right;
        }

        .footer-link {
            color: var(--text-color);
            text-decoration: none;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            transition: 0.3s;
        }

        .footer-link:hover {
            opacity: 0.5;
        }

        /* Responsive Design */
        @media (max-width: 900px) {
            main {
                flex-direction: column;
                padding: 0 40px;
                text-align: center;
            }
            .left-mid, .right-mid {
                text-align: center;
                margin: 20px 0;
            }
            footer {
                flex-direction: column;
                align-items: center;
                text-align: center;
                gap: 30px;
                padding: 20px;
            }
            .footer-left {
                flex-direction: column;
                gap: 15px;
            }
            .footer-right {
                text-align: center;
            }
            h1 {
                letter-spacing: 10px;
            }
            .nav-links {
                gap: 20px;
                padding: 10px 20px;
            }
        }
    </style>
</head>
<body>

    <!-- Navigation (Restored) -->
    <nav>
        <ul class="nav-links">
            <li><a href="#">About</a></li>
            <li><a href="#">Vision</a></li>
            <li><a href="#">Schemes</a></li>
        </ul>
    </nav>

    <!-- Top Center Title -->
    <header>
        <h1>NEUROSCHOLAR</h1>
    </header>

    <!-- Middle Split Content -->
    <main>
        <div class="middle-text left-mid">
            All your scholarships<br>at one site. Your AI mentor.
        </div>

        <div class="middle-text right-mid">
            All your scholarships<br>at one site. Your AI mentor.
        </div>
    </main>

    <!-- Bottom Corners -->
    <footer>
        <div class="footer-left">
            <a href="#" class="footer-link">Login</a>
            <a href="#" class="footer-link">Registration</a>
        </div>

        <div class="footer-right">
            <a href="#" class="footer-link">Find Scholarship →</a>
        </div>
    </footer>

</body>
</html>
